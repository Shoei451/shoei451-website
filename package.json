{
  "name": "shoei451-website",
  "private": true,
  "version": "1.0.0",
  "description": "Operational checks for the shoei451-website",
  "scripts": {
    "check:js": "node scripts/check-js.mjs",
    "check:links": "node scripts/check-links.mjs",
    "check": "npm run check:js && npm run check:links",
    "tree": "npx tree-node-cli -L 3 -I \"node_modules,.git,dist,.next\"",
    "compress": "shx rm -rf dist && esbuild src/**/*.js src/**/*.css --minify --outdir=dist --outbase=src && shx cp -r src/**/*.html src/**/*.png src/**/*.jpg dist/",
    "dev" : "npx serve src"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "shx": "^0.4.0",
    "tree-node-cli": "^1.6.0"
  },
  "dependencies": {
    "bootstrap-icons": "^1.13.1",
    "glob": "^13.0.6",
    "rimraf": "^6.1.3"
  },
  "overrides": {
    "brace-expansion": "^2.0.1"
  }
}
